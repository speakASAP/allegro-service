generator client {
  provider      = "prisma-client-js"
  output        = "../shared/node_modules/.prisma/client"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

generator client_default {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Product model removed - all products are now managed by catalog-microservice
// Use catalogProductId (UUID) to reference products from catalog-microservice

// Allegro products (raw productSet data)
model AllegroProduct {
  id                 String   @id @default(uuid()) @db.Uuid
  allegroProductId   String   @unique @db.VarChar(100)
  name               String?  @db.VarChar(500)
  brand              String?  @db.VarChar(255)
  manufacturerCode   String?  @db.VarChar(255)
  ean                String?  @db.VarChar(50)
  publicationStatus  String?  @db.VarChar(50)
  isAiCoCreated      Boolean  @default(false)
  marketedBeforeGPSR Boolean?
  rawData            Json
  createdAt          DateTime @default(now()) @db.Timestamp(6)
  updatedAt          DateTime @updatedAt @db.Timestamp(6)

  // Relations
  offers     AllegroOffer[]
  parameters AllegroProductParameter[]

  @@index([allegroProductId])
  @@map("allegro_products")
}

model AllegroProductParameter {
  id               String   @id @default(uuid()) @db.Uuid
  allegroProductId String   @db.Uuid
  parameterId      String   @db.VarChar(100)
  name             String?  @db.VarChar(255)
  values           Json?
  valuesIds        Json?
  rangeValue       Json?
  createdAt        DateTime @default(now()) @db.Timestamp(6)
  updatedAt        DateTime @updatedAt @db.Timestamp(6)

  // Relations
  product AllegroProduct @relation(fields: [allegroProductId], references: [id], onDelete: Cascade)

  @@unique([allegroProductId, parameterId])
  @@index([parameterId])
  @@map("allegro_product_parameters")
}

// Allegro offers mapped to catalog-microservice products
model AllegroOffer {
  id                String  @id @default(uuid()) @db.Uuid
  catalogProductId  String? @db.Uuid // Product ID from catalog-microservice (no FK constraint)
  allegroProductId  String? @db.Uuid
  allegroOfferId    String  @unique @db.VarChar(100) // Allegro's offer ID
  allegroListingId  String? @db.VarChar(100) // Allegro's listing ID

  // Offer details
  title         String  @db.VarChar(500)
  description   String? @db.Text
  categoryId    String  @db.VarChar(100)
  price         Decimal @db.Decimal(10, 2)
  currency      String  @default("PLN") @db.VarChar(10)
  quantity      Int     @default(1)
  stockQuantity Int     @default(0)

  // Status
  status            String  @db.VarChar(50) // ACTIVE, INACTIVE, ENDED, etc.
  publicationStatus String? @db.VarChar(50) // ACTIVE, INACTIVE, etc.

  // Delivery and payment
  deliveryOptions Json? // Delivery methods
  paymentOptions  Json? // Payment methods

  // Images
  images Json? // Array of image URLs

  // Full raw payload from Allegro API
  rawData Json? // Complete Allegro /sale/offers payload for full fidelity

  // Sync metadata
  lastSyncedAt DateTime? @db.Timestamp(6)
  syncStatus   String    @default("PENDING") @db.VarChar(50) // PENDING, SYNCED, ERROR
  syncError    String?   @db.Text
  syncSource   String?   @db.VarChar(50) // ALLEGRO_API, SALES_CENTER, MANUAL, etc.

  // Validation/readiness for publish flows
  validationStatus String?   @db.VarChar(50) // READY, WARNINGS, ERRORS
  validationErrors Json? // Array of validation error/warning objects
  lastValidatedAt  DateTime? @db.Timestamp(6)

  // Multi-account support
  accountId    String? @db.Uuid // Links to AllegroAccount that owns this offer
  clonedFromId String? @db.Uuid // Reference to source offer if cloned

  // Responsible producer (required for GPSR compliance)
  responsibleProducerId String? @db.Uuid // Links to ResponsibleProducer

  // Timestamps
  createdAt DateTime @default(now()) @db.Timestamp(6)
  updatedAt DateTime @updatedAt @db.Timestamp(6)

  // Relations
  // NOTE: catalogProductId references catalog-microservice product ID (no foreign key constraint)
  orders          AllegroOrder[]
  orderLineItems  AllegroOrderLineItem[]
  syncJobs        SyncJob[]
  publishAttempts AllegroPublishAttempt[]
  stockSnapshots  AllegroOfferStockSnapshot[]

  allegroProduct       AllegroProduct?        @relation(fields: [allegroProductId], references: [id], onDelete: SetNull)
  account              AllegroAccount?        @relation(fields: [accountId], references: [id], onDelete: SetNull)
  responsibleProducer  ResponsibleProducer?  @relation(fields: [responsibleProducerId], references: [id], onDelete: SetNull)

  @@index([allegroOfferId])
  @@index([catalogProductId])
  @@index([allegroProductId])
  @@index([status])
  @@index([syncStatus])
  @@index([createdAt])
  @@index([title]) // Index for fast text search
  @@index([categoryId]) // Index for fast category filtering
  @@index([accountId]) // Index for fast account filtering
  @@index([responsibleProducerId]) // Index for producer filtering
  @@map("allegro_offers")
}

// Governed publish/update attempt lifecycle for Allegro offer mutations
model AllegroPublishAttempt {
  id                String   @id @default(uuid()) @db.Uuid
  action            String   @db.VarChar(50) // PUBLISH, UPDATE, END
  status            String   @db.VarChar(50) // PREPARED, BLOCKED, CONFIRMED, QUEUED, RUNNING, SUCCEEDED, FAILED, CANCELLED, STALE
  idempotencyKey    String   @unique @db.VarChar(160)
  requestedByUserId String   @db.VarChar(255)

  accountId        String? @db.Uuid
  catalogProductId String? @db.Uuid // Product ID from catalog-microservice (no FK constraint)
  offerId          String? @db.Uuid
  allegroOfferId   String? @db.VarChar(100)
  commandId        String? @db.VarChar(255)

  commandPayload     Json?
  policySnapshot     Json
  blockedReasons     Json?
  failureContext     Json?
  remediationContext Json?

  preparedAt  DateTime  @default(now()) @db.Timestamp(6)
  confirmedAt DateTime? @db.Timestamp(6)
  queuedAt    DateTime? @db.Timestamp(6)
  startedAt   DateTime? @db.Timestamp(6)
  completedAt DateTime? @db.Timestamp(6)
  staleAt     DateTime? @db.Timestamp(6)
  createdAt   DateTime  @default(now()) @db.Timestamp(6)
  updatedAt   DateTime  @updatedAt @db.Timestamp(6)

  offer   AllegroOffer?   @relation(fields: [offerId], references: [id], onDelete: SetNull)
  account AllegroAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)

  @@index([action])
  @@index([status])
  @@index([accountId])
  @@index([catalogProductId])
  @@index([offerId])
  @@index([allegroOfferId])
  @@index([commandId])
  @@index([createdAt])
  @@index([staleAt])
  @@map("allegro_publish_attempts")
}

// Account-aware sync run evidence for Allegro channel imports, audits, and future exports.
model AllegroSyncRun {
  id                String    @id @default(uuid()) @db.Uuid
  accountId         String    @db.Uuid
  domain            String    @db.VarChar(80)
  direction         String    @db.VarChar(30)
  mode              String    @db.VarChar(30)
  status            String    @db.VarChar(50)
  idempotencyKey    String?   @unique @db.VarChar(160)
  startedAt         DateTime  @default(now()) @db.Timestamp(6)
  completedAt       DateTime? @db.Timestamp(6)
  scannedCount      Int       @default(0)
  createdCount      Int       @default(0)
  updatedCount      Int       @default(0)
  unchangedCount    Int       @default(0)
  skippedCount      Int       @default(0)
  failedCount       Int       @default(0)
  cursorBefore      Json?
  cursorAfter       Json?
  configSnapshot    Json?
  errorSummary      Json?
  createdByUserId   String?   @db.VarChar(255)
  createdAt         DateTime  @default(now()) @db.Timestamp(6)
  updatedAt         DateTime  @updatedAt @db.Timestamp(6)

  account             AllegroAccount               @relation(fields: [accountId], references: [id], onDelete: Restrict)
  cursors             AllegroSyncCursor[]          @relation("AllegroSyncCursorLastRun")
  rawPayloads         AllegroRawPayload[]
  projectionAuditLogs AllegroProjectionAuditLog[]
  stockSnapshots      AllegroOfferStockSnapshot[]

  @@index([accountId])
  @@index([domain])
  @@index([direction])
  @@index([mode])
  @@index([status])
  @@index([startedAt])
  @@index([completedAt])
  @@map("allegro_sync_runs")
}

// Per-account cursor and watermark ownership for deterministic Allegro syncs.
model AllegroSyncCursor {
  id          String    @id @default(uuid()) @db.Uuid
  accountId   String    @db.Uuid
  domain      String    @db.VarChar(80)
  endpoint    String    @db.VarChar(500)
  cursorType  String    @db.VarChar(80)
  cursorValue String?   @db.Text
  watermarkAt DateTime? @db.Timestamp(6)
  lastRunId   String?   @db.Uuid
  lockedUntil DateTime? @db.Timestamp(6)
  createdAt   DateTime  @default(now()) @db.Timestamp(6)
  updatedAt   DateTime  @updatedAt @db.Timestamp(6)

  account AllegroAccount  @relation(fields: [accountId], references: [id], onDelete: Restrict)
  lastRun AllegroSyncRun? @relation("AllegroSyncCursorLastRun", fields: [lastRunId], references: [id], onDelete: SetNull)

  @@unique([accountId, domain, endpoint, cursorType])
  @@index([accountId])
  @@index([domain])
  @@index([endpoint])
  @@index([lastRunId])
  @@index([lockedUntil])
  @@index([updatedAt])
  @@map("allegro_sync_cursors")
}

// Immutable raw Allegro payload evidence with PII classification and hashes.
model AllegroRawPayload {
  id               String   @id @default(uuid()) @db.Uuid
  syncRunId        String?  @db.Uuid
  accountId        String   @db.Uuid
  domain           String   @db.VarChar(80)
  endpoint         String   @db.VarChar(500)
  externalId       String   @db.VarChar(255)
  revision         String?  @db.VarChar(255)
  payloadHash      String   @db.VarChar(128)
  payload          Json
  piiClass         String   @db.VarChar(50)
  redactionVersion String   @db.VarChar(50)
  receivedAt       DateTime @default(now()) @db.Timestamp(6)
  createdAt        DateTime @default(now()) @db.Timestamp(6)

  account        AllegroAccount              @relation(fields: [accountId], references: [id], onDelete: Restrict)
  syncRun        AllegroSyncRun?             @relation(fields: [syncRunId], references: [id], onDelete: SetNull)
  stockSnapshots AllegroOfferStockSnapshot[]

  @@unique([accountId, domain, externalId, payloadHash])
  @@index([syncRunId])
  @@index([accountId])
  @@index([domain])
  @@index([endpoint])
  @@index([externalId])
  @@index([payloadHash])
  @@index([receivedAt])
  @@map("allegro_raw_payloads")
}

// Append-only projection change evidence for replay and audit reviews.
model AllegroProjectionAuditLog {
  id              String   @id @default(uuid()) @db.Uuid
  syncRunId       String?  @db.Uuid
  accountId       String   @db.Uuid
  entityType      String   @db.VarChar(80)
  entityId        String?  @db.Uuid
  externalId      String?  @db.VarChar(255)
  action          String   @db.VarChar(50)
  beforeHash      String?  @db.VarChar(128)
  afterHash       String?  @db.VarChar(128)
  diffSummary     Json?
  redactedContext Json?
  idempotencyKey  String?  @db.VarChar(160)
  createdAt       DateTime @default(now()) @db.Timestamp(6)

  account AllegroAccount  @relation(fields: [accountId], references: [id], onDelete: Restrict)
  syncRun AllegroSyncRun? @relation(fields: [syncRunId], references: [id], onDelete: SetNull)

  @@index([syncRunId])
  @@index([accountId])
  @@index([entityType])
  @@index([entityId])
  @@index([externalId])
  @@index([action])
  @@index([idempotencyKey])
  @@index([createdAt])
  @@map("allegro_projection_audit_logs")
}

// Current Allegro listing stock snapshots; Warehouse remains physical stock owner.
model AllegroOfferStockSnapshot {
  id                String   @id @default(uuid()) @db.Uuid
  syncRunId         String?  @db.Uuid
  accountId         String   @db.Uuid
  offerId           String?  @db.Uuid
  allegroOfferId    String   @db.VarChar(100)
  catalogProductId  String?  @db.Uuid
  sourceEndpoint    String   @db.VarChar(500)
  sourceFetchedAt   DateTime @default(now()) @db.Timestamp(6)
  payloadHash       String   @db.VarChar(128)
  availableQuantity Int?
  authorityClass    String   @db.VarChar(80)
  rawPayloadId      String?  @db.Uuid
  comparisonSummary Json?
  createdAt         DateTime @default(now()) @db.Timestamp(6)

  account    AllegroAccount     @relation(fields: [accountId], references: [id], onDelete: Restrict)
  syncRun    AllegroSyncRun?    @relation(fields: [syncRunId], references: [id], onDelete: SetNull)
  offer      AllegroOffer?      @relation(fields: [offerId], references: [id], onDelete: SetNull)
  rawPayload AllegroRawPayload? @relation(fields: [rawPayloadId], references: [id], onDelete: SetNull)

  @@index([syncRunId])
  @@index([accountId])
  @@index([offerId])
  @@index([allegroOfferId])
  @@index([catalogProductId])
  @@index([rawPayloadId])
  @@index([sourceFetchedAt])
  @@index([authorityClass])
  @@map("allegro_offer_stock_snapshots")
}

// Orders from Allegro
model AllegroOrder {
  id              String  @id @default(uuid()) @db.Uuid
  allegroOrderId  String  @unique @db.VarChar(100) // Allegro's order ID
  allegroOfferId  String? @db.Uuid
  catalogProductId String? @db.Uuid // Product ID from catalog-microservice (no FK constraint)

  // Order details
  buyerId    String? @db.VarChar(100)
  buyerEmail String? @db.VarChar(255)
  buyerLogin String? @db.VarChar(255)

  // Order items
  quantity   Int     @default(1)
  price      Decimal @db.Decimal(10, 2)
  totalPrice Decimal @db.Decimal(10, 2)
  currency   String  @default("PLN") @db.VarChar(10)
  lineItemsCount Int  @default(0)

  // Status
  status            String  @db.VarChar(50) // NEW, PAID, SENT, DELIVERED, CANCELLED
  paymentStatus     String? @db.VarChar(50) // PAID, UNPAID, REFUNDED
  fulfillmentStatus String? @db.VarChar(50) // NEW, PROCESSING, SENT, DELIVERED

  // Delivery
  deliveryMethod  String? @db.VarChar(100)
  deliveryAddress Json? // Address object
  trackingNumber  String? @db.VarChar(255)

  // Payment
  paymentMethod String?   @db.VarChar(100)
  paidAt        DateTime? @db.Timestamp(6)

  // Checkout form metadata
  marketplaceId   String? @db.VarChar(100)
  revision        String? @db.VarChar(100)
  invoiceRequired Boolean @default(false)
  rawData         Json?

  // Timestamps
  orderDate DateTime @db.Timestamp(6)
  createdAt DateTime @default(now()) @db.Timestamp(6)
  updatedAt DateTime @updatedAt @db.Timestamp(6)

  // Relations
  offer     AllegroOffer? @relation(fields: [allegroOfferId], references: [id], onDelete: SetNull)
  lineItems AllegroOrderLineItem[]
  forwardingAttempts AllegroOrderForwardingAttempt[]
  // NOTE: catalogProductId references catalog-microservice product ID (no foreign key constraint)

  @@index([allegroOrderId])
  @@index([allegroOfferId])
  @@index([catalogProductId])
  @@index([status])
  @@index([orderDate])
  @@index([marketplaceId])
  @@map("allegro_orders")
}


model AllegroOrderForwardingAttempt {
  id                     String    @id @default(uuid()) @db.Uuid
  localOrderId           String    @db.Uuid
  accountId              String?   @db.Uuid
  allegroOrderId         String    @db.VarChar(100)
  channel                String    @default("allegro") @db.VarChar(50)
  channelAccountId       String    @default("default") @db.VarChar(100)
  externalOrderId        String    @db.VarChar(100)
  contractVersion        String    @default("orders.create.v1") @db.VarChar(50)
  idempotencyKey         String    @db.VarChar(180)
  payloadHash            String?   @db.VarChar(128)
  payloadEqualityStatus  String    @default("NOT_APPLICABLE") @db.VarChar(50)
  previousAttemptId      String?   @db.Uuid
  status                 String    @db.VarChar(50)
  blockedReasons         Json?
  missingOfferIds        Json?
  missingCatalogOfferIds Json?
  requestSummary         Json?
  responseSummary        Json?
  errorSummary           Json?
  attemptedAt            DateTime  @default(now()) @db.Timestamp(6)
  completedAt            DateTime? @db.Timestamp(6)
  createdAt              DateTime  @default(now()) @db.Timestamp(6)
  updatedAt              DateTime  @updatedAt @db.Timestamp(6)

  order   AllegroOrder    @relation(fields: [localOrderId], references: [id], onDelete: Cascade)
  account AllegroAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)

  @@unique([idempotencyKey])
  @@index([localOrderId])
  @@index([accountId])
  @@index([allegroOrderId])
  @@index([channel, channelAccountId, externalOrderId])
  @@index([payloadHash])
  @@index([payloadEqualityStatus])
  @@index([status])
  @@index([attemptedAt])
  @@map("allegro_order_forwarding_attempts")
}

model AllegroOrderLineItem {
  id                     String   @id @default(uuid()) @db.Uuid
  orderId                String   @db.Uuid
  allegroLineItemId      String   @db.VarChar(150)
  allegroOfferExternalId String?  @db.VarChar(100)
  allegroOfferId         String?  @db.Uuid
  catalogProductId       String?  @db.Uuid // Product ID from catalog-microservice (no FK constraint)

  title         String  @db.VarChar(500)
  quantity      Int     @default(1)
  price         Decimal @db.Decimal(10, 2)
  originalPrice Decimal? @db.Decimal(10, 2)
  totalPrice    Decimal @db.Decimal(10, 2)
  currency      String  @default("PLN") @db.VarChar(10)

  tax                        Json?
  discounts                  Json?
  vouchers                   Json?
  selectedAdditionalServices Json?
  rawData                    Json?
  boughtAt                   DateTime? @db.Timestamp(6)

  createdAt DateTime @default(now()) @db.Timestamp(6)
  updatedAt DateTime @updatedAt @db.Timestamp(6)

  order AllegroOrder  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  offer AllegroOffer? @relation(fields: [allegroOfferId], references: [id], onDelete: SetNull)

  @@unique([orderId, allegroLineItemId])
  @@index([allegroLineItemId])
  @@index([allegroOfferExternalId])
  @@index([allegroOfferId])
  @@index([catalogProductId])
  @@index([boughtAt])
  @@map("allegro_order_line_items")
}

// Sync job tracking
model SyncJob {
  id          String    @id @default(uuid()) @db.Uuid
  type        String    @db.VarChar(50) // DB_TO_ALLEGRO, ALLEGRO_TO_DB, INVENTORY
  direction   String    @db.VarChar(50) // TO_ALLEGRO, FROM_ALLEGRO, BIDIRECTIONAL
  status      String    @db.VarChar(50) // PENDING, RUNNING, COMPLETED, FAILED
  startedAt   DateTime? @db.Timestamp(6)
  completedAt DateTime? @db.Timestamp(6)

  // Statistics
  totalItems      Int @default(0)
  processedItems  Int @default(0)
  successfulItems Int @default(0)
  failedItems     Int @default(0)

  // Error tracking
  errors       Json? // Array of error objects
  errorMessage String? @db.Text

  // Metadata
  metadata Json? // Additional job metadata

  // Relations
  allegroOfferId String?       @db.Uuid
  offer          AllegroOffer? @relation(fields: [allegroOfferId], references: [id])

  createdAt DateTime @default(now()) @db.Timestamp(6)
  updatedAt DateTime @updatedAt @db.Timestamp(6)

  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@map("sync_jobs")
}

// CSV import job tracking
model ImportJob {
  id       String  @id @default(uuid()) @db.Uuid
  fileName String  @db.VarChar(500)
  filePath String? @db.VarChar(1000)
  fileSize BigInt? @db.BigInt
  mimeType String? @db.VarChar(100)

  // Status
  status      String    @db.VarChar(50) // PENDING, PROCESSING, COMPLETED, FAILED
  startedAt   DateTime? @db.Timestamp(6)
  completedAt DateTime? @db.Timestamp(6)

  // Statistics
  totalRows      Int @default(0)
  processedRows  Int @default(0)
  successfulRows Int @default(0)
  failedRows     Int @default(0)
  skippedRows    Int @default(0)

  // Error tracking
  errors       Json? // Array of error objects with row numbers
  errorMessage String? @db.Text

  // Metadata
  source   String @default("BIZBOX") @db.VarChar(50) // BIZBOX, MANUAL, API
  metadata Json? // Additional import metadata
  catalogProductId String? @db.Uuid // Product ID from catalog-microservice (no FK constraint)

  createdAt DateTime @default(now()) @db.Timestamp(6)
  updatedAt DateTime @updatedAt @db.Timestamp(6)

  @@index([status])
  @@index([source])
  @@index([catalogProductId])
  @@index([createdAt])
  @@map("import_jobs")
}

// Webhook events log
model WebhookEvent {
  id        String @id @default(uuid()) @db.Uuid
  eventId   String @unique @db.VarChar(255) // Allegro's event ID
  eventType String @db.VarChar(100) // order.created, order.updated, offer.updated, etc.
  source    String @default("ALLEGRO") @db.VarChar(50)

  // Event data
  payload     Json // Full webhook payload
  processed   Boolean   @default(false)
  processedAt DateTime? @db.Timestamp(6)

  // Error tracking
  processingError String? @db.Text
  retryCount      Int     @default(0)

  createdAt DateTime @default(now()) @db.Timestamp(6)
  updatedAt DateTime @updatedAt @db.Timestamp(6)

  @@index([eventType])
  @@index([processed])
  @@index([createdAt])
  @@map("webhook_events")
}

// Supplier products (placeholder for future integration)
// References catalog-microservice products via catalogProductId
model SupplierProduct {
  id              String  @id @default(uuid()) @db.Uuid
  catalogProductId String @db.Uuid // Product ID from catalog-microservice (no FK constraint)
  supplierId      String  @db.VarChar(100)
  supplierCode    String  @db.VarChar(255)
  supplierName    String? @db.VarChar(255)

  // Supplier-specific data
  supplierPrice    Decimal? @db.Decimal(10, 2)
  supplierCurrency String?  @db.VarChar(10)
  supplierStock    Int?     @default(0)
  supplierUrl      String?  @db.VarChar(1000)

  // Sync metadata
  lastSyncedAt DateTime? @db.Timestamp(6)
  syncStatus   String    @default("PENDING") @db.VarChar(50)
  syncError    String?   @db.Text

  // API configuration (placeholder)
  apiEndpoint String? @db.VarChar(1000)
  apiKey      String? @db.VarChar(500)
  apiConfig   Json? // Additional API configuration

  createdAt DateTime @default(now()) @db.Timestamp(6)
  updatedAt DateTime @updatedAt @db.Timestamp(6)

  @@unique([supplierId, supplierCode])
  @@index([catalogProductId])
  @@index([supplierId])
  @@index([syncStatus])
  @@map("supplier_products")
}

// Responsible producers - account-specific producers from Allegro
model ResponsibleProducer {
  id        String  @id @default(uuid()) @db.Uuid
  accountId String  @db.Uuid // Links to AllegroAccount
  producerId String @db.VarChar(100) // Allegro's producer ID

  // Producer data from Allegro API
  name        String? @db.VarChar(500)
  email       String? @db.VarChar(255)
  phone       String? @db.VarChar(50)
  address     Json? // Address object
  rawData     Json // Full producer data from Allegro API

  // Sync metadata
  lastSyncedAt DateTime? @db.Timestamp(6)
  syncStatus   String    @default("SYNCED") @db.VarChar(50) // SYNCED, ERROR
  syncError    String?   @db.Text

  // Timestamps
  createdAt DateTime @default(now()) @db.Timestamp(6)
  updatedAt DateTime @updatedAt @db.Timestamp(6)

  // Relations
  account AllegroAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  offers  AllegroOffer[]

  @@unique([accountId, producerId])
  @@index([accountId])
  @@index([producerId])
  @@map("responsible_producers")
}

// Allegro accounts - multiple accounts per user
model AllegroAccount {
  id     String @id @default(uuid()) @db.Uuid
  userId String @db.VarChar(255) // Links to auth-microservice user ID

  // Account name (user-provided, e.g., "statexcz", "flipflop")
  name String @db.VarChar(255)

  // Allegro API configuration
  clientId     String? @db.VarChar(255)
  clientSecret String? @db.Text // Encrypted (can be up to ~1000 chars when encrypted, use Text to avoid truncation)

  // Allegro OAuth tokens (for accessing user-specific resources)
  accessToken       String?   @db.VarChar(5000) // Encrypted
  refreshToken      String?   @db.VarChar(5000) // Encrypted
  tokenExpiresAt    DateTime? @db.Timestamp(6)
  tokenScopes       String?   @db.VarChar(1000) // Comma-separated scopes
  oAuthState        String?   @db.VarChar(255) // For OAuth state verification
  oAuthCodeVerifier String?   @db.VarChar(500) // Encrypted, for PKCE

  // Active account flag (only one active per user)
  isActive Boolean @default(false)

  // Timestamps
  createdAt DateTime @default(now()) @db.Timestamp(6)
  updatedAt DateTime @updatedAt @db.Timestamp(6)

  // Relations
  offers          AllegroOffer[]
  producers       ResponsibleProducer[]
  publishAttempts AllegroPublishAttempt[]
  syncRuns        AllegroSyncRun[]
  syncCursors     AllegroSyncCursor[]
  rawPayloads     AllegroRawPayload[]
  projectionAuditLogs AllegroProjectionAuditLog[]
  stockSnapshots  AllegroOfferStockSnapshot[]
  orderForwardingAttempts AllegroOrderForwardingAttempt[]

  @@index([userId])
  @@index([isActive])
  @@index([userId, isActive])
  @@map("allegro_accounts")
}

// User settings for API keys and configuration
model UserSettings {
  id     String @id @default(uuid()) @db.Uuid
  userId String @unique @db.VarChar(255) // Links to auth-microservice user ID

  // Generic supplier configurations
  supplierConfigs Json? // Array of supplier configurations: [{ id, name, apiEndpoint, apiKey, apiConfig }]

  // User preferences
  preferences Json? // User preferences and settings (activeAllegroAccountId stored here)

  // Timestamps
  createdAt DateTime @default(now()) @db.Timestamp(6)
  updatedAt DateTime @updatedAt @db.Timestamp(6)

  @@index([userId])
  @@map("user_settings")
}
